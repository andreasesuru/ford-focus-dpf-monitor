<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Tab bar (shared across all screens) ──────────────────────────── -->
    <include layout="@layout/layout_tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ── Body content (slides during tab transitions) ─────────────────── -->
    <LinearLayout
        android:id="@+id/contentBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

    <!-- ── Mock data banner — visible only when showing demo sessions ────── -->
    <TextView
        android:id="@+id/tvMockBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👁  DATI DI ESEMPIO — nessuna rigenerazione reale ancora registrata"
        android:textColor="#000000"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp"
        android:background="#FFFF9F0A"
        android:visibility="gone"/>

    <!-- ── Stats bar ────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvTotalRegens"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#4F8EF7"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TOTALI" android:textSize="9sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvCompleted"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#34C759"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="COMPLET." android:textSize="9sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvAvgDuration"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DURATA" android:textSize="9sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvAvgSootReduction"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#34C759"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SOOT MED." android:textSize="9sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Export button ────────────────────────────────────────────────── -->
    <Button
        android:id="@+id/btnExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="📄  Esporta report per meccanico"
        android:textSize="13sp"
        android:textColor="#4F8EF7"
        android:backgroundTint="@android:color/transparent"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <!-- ── Soot history bar chart (visible only when sessions exist) ──────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSootChart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SOOT PRIMA / DOPO REGEN"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartSootHistory"
                android:layout_width="match_parent"
                android:layout_height="160dp"/>

            <!-- Legend -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="6dp">

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="#FF3B30"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prima"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginEnd="16dp"/>

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="#00C853"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dopo"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Empty state ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/viewEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📋" android:textSize="48sp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nessuna rigenerazione registrata"
            android:textColor="@color/text_primary" android:textSize="16sp"
            android:textStyle="bold" android:gravity="center" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Lo storico si popola automaticamente quando l'app rileva una rigenerazione attiva del DPF."
            android:textColor="@color/text_secondary" android:textSize="13sp"
            android:gravity="center" android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <!-- ── Sessions list ─────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSessions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>

    </LinearLayout><!-- end contentBody -->

    <!-- ── Footer (shared) ──────────────────────────────────────────────── -->
    <include layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
