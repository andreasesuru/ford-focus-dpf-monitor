<?xml version="1.0" encoding="utf-8"?>
<!--
    ECU PID Scanner UI.
    Dark automotive theme matching MainActivity.
    Layout:
      • Toolbar (title + back navigation)
      • Stats card — current phase, progress bar, ✓ ✗ – counts
      • Scrollable log area — live results as they stream in
      • Bottom action bar — Stop / Share buttons
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Toolbar ──────────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_background"
        app:title="ECU PID Scanner"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/text_primary" />

    <!-- ── Stats card ───────────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/card_background"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Phase name -->
            <TextView
                android:id="@+id/tvCurrentPhase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to scan"
                android:textColor="@color/dpf_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Phase progress bar -->
            <ProgressBar
                android:id="@+id/progressPhase"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/dpf_orange"
                android:layout_marginBottom="12dp" />

            <!-- Counts row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Responded ✓ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCountResponded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/status_ok"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ Replied"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Negative ✗ -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCountNegative"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/status_warning"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ Negative"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Timeout – -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCountTimeout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_secondary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="– Timeout"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Scrollable log area ──────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="12dp"
        android:background="@color/card_background"
        android:padding="0dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="2dp"
            android:text="Tap &#34;Start Scan&#34; to begin ECU PID discovery.\n\nMake sure the OBD dongle is connected first." />

    </ScrollView>

    <!-- ── Bottom action bar ────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/card_background"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Start Scan"
            android:textSize="13sp"
            app:backgroundTint="@color/dpf_blue_light" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Stop"
            android:visibility="gone"
            app:backgroundTint="@color/status_danger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share Log"
            android:enabled="false"
            app:backgroundTint="@color/status_ok" />

    </LinearLayout>

</LinearLayout>
