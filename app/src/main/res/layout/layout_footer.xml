<?xml version="1.0" encoding="utf-8"?>
<!--
    Shared footer bar — included in all tab activity layouts.
    MainActivity binds tvFooterVersion + tvFooterGithub dynamically;
    other activities use it as static display only.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingVertical="10dp"
    android:background="#000000">

    <!-- Thin top divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Andrea Sesuru"
            android:textColor="#6A7D90"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#6A7D90"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvFooterGithub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="github.com/andreasesuru"
            android:textColor="#4F8EF7"
            android:textSize="12sp"
            android:paddingVertical="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#6A7D90"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvFooterVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v4.7"
            android:textColor="#6A7D90"
            android:textSize="12sp"/>

    </LinearLayout>
</LinearLayout>
