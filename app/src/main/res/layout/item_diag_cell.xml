<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable diagnostic data cell.
    Used in activity_diagnostica.xml via <include>.

    Layout:
      ┌─┬──────────────────────────┐
      │▓│ LABEL                    │  ← colored left accent bar
      │▓│ VALUE (large)  UNIT      │
      │▓│ hint text                │
      └─┴──────────────────────────┘
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:minHeight="80dp">

    <!-- Left accent bar — color driven by value status (green / amber / red / muted) -->
    <View
        android:id="@+id/vCellStatusBar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#1E2A3A"/>

    <!-- Cell content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Sensor label -->
        <TextView
            android:id="@+id/tvCellLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LABEL"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:layout_marginBottom="4dp"/>

        <!-- Value + unit row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/tvCellValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:id="@+id/tvCellUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="3dp"/>

        </LinearLayout>

        <!-- Context hint — human-readable normal range -->
        <TextView
            android:id="@+id/tvCellHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:layout_marginTop="3dp"/>

    </LinearLayout>

</LinearLayout>
