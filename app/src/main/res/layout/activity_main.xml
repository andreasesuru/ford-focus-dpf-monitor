<?xml version="1.0" encoding="utf-8"?>
<!--
    Phone UI - MainActivity layout.
    Dark automotive theme, card-based layout with ScrollView.
    Mirrors the Android Auto data display + adds BLE scan/connect controls.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Shared tab bar (header + 3 tabs) -->
    <include layout="@layout/layout_tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ── Footer — always visible below scroll content ──────────────────── -->
    <!-- Declared before ScrollView but placed at bottom via layout_gravity  -->

    <ScrollView
        android:id="@+id/contentBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- tvAppVersion kept hidden — still bound in MainActivity for version display -->
            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="v3.4" />

            <!-- BLE Connection Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:animateLayoutChanges="true">

                    <!-- ── Accordion header: always visible ──────────────────── -->
                    <LinearLayout
                        android:id="@+id/layoutConnectionHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OBD2 Connection"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvConnectionStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_disconnected"
                                android:textColor="@color/status_neutral"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <!-- Chevron: ▾ = expanded, ▸ = collapsed -->
                        <TextView
                            android:id="@+id/tvConnectionChevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▾"
                            android:textColor="@color/text_secondary"
                            android:textSize="18sp"
                            android:paddingStart="8dp" />

                    </LinearLayout>

                    <!-- ── Collapsible section: scan / disconnect / ECU ───────── -->
                    <!-- Starts VISIBLE (disconnected = user needs to connect) -->
                    <LinearLayout
                        android:id="@+id/layoutConnectionButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_horizontal"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnScan"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="@string/btn_scan"
                                android:textSize="12sp"
                                app:backgroundTint="@color/dpf_blue_light" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDisconnect"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_disconnect"
                                android:visibility="gone"
                                app:backgroundTint="@color/status_danger" />

                        </LinearLayout>

                        <!-- ECU Scanner button — visible only when connected -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnScanEcu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Scansiona ECU PIDs"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:backgroundTint="@color/dpf_blue_dark"
                            app:strokeColor="@color/dpf_orange"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DPF Load + Soot Card — circular PieChart gauges -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DPF STATUS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp" />

                    <!-- Hidden note (set via code when needed) -->
                    <TextView
                        android:id="@+id/tvDpfNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp" />

                    <!-- ── Gauge row: LOAD | SOOT ─────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- LOAD gauge -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="128dp"
                                android:layout_height="128dp">

                                <com.github.mikephil.charting.charts.PieChart
                                    android:id="@+id/chartDpfLoad"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent" />

                                <!-- Centre overlay: value + unit -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <TextView
                                        android:id="@+id/tvDpfLoad"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="—"
                                        android:textColor="@color/text_primary"
                                        android:textSize="24sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="%"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                </LinearLayout>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_dpf_load"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>

                        <!-- SOOT gauge -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="128dp"
                                android:layout_height="128dp">

                                <com.github.mikephil.charting.charts.PieChart
                                    android:id="@+id/chartDpfSoot"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent" />

                                <!-- Centre overlay: value + unit -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <TextView
                                        android:id="@+id/tvDpfSoot"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="—"
                                        android:textColor="@color/text_primary"
                                        android:textSize="24sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="%"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                </LinearLayout>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_dpf_soot"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_border"
                        android:layout_marginBottom="12dp" />

                    <!-- DPF Delta Pressure row (PID 01 7A) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DPF Delta P (01 7A)"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvDpfDeltaNote"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="idle ~0 | cruise 5-15 kPa"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDpfDeltaP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Regeneration Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_regen_status"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvRegenStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/regen_inactive"
                        android:textColor="@color/status_ok"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Temperatures Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Temperature"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- EGT row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_egt"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvEgt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Coolant Temp row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_coolant"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvCoolant"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Distanze ECU Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distanze (ECU)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Odometer - PID 22 DD01 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Odometro (TOT)"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvOdometer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Km dall'ultima rigenerazione - PID 22 050B -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ultima regen (LST REG)"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvLastRegen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Km dall'ultimo cambio olio - PID 22 0542 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cambio olio (OILCHG)"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvOilChange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/value_no_data"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Footer ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:background="#000000">

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0F0F0F"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Andrea Sesuru"
                android:textColor="#6A7D90"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#6A7D90"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvFooterGithub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="github.com/andreasesuru"
                android:textColor="#4F8EF7"
                android:textSize="12sp"
                android:paddingVertical="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#6A7D90"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvFooterVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v3.4"
                android:textColor="#6A7D90"
                android:textSize="12sp"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
