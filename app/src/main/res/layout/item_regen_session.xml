<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:clipToPadding="true">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvSessionNum"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4F8EF7"
            android:background="@drawable/bg_num_badge"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvSessionDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSessionOdo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

            <!-- Regen type badge: ACTIVE = forzata ECU / WARNING = passiva temperatura -->
            <TextView
                android:id="@+id/tvRegenType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="7dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_tab_inactive"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#34C759"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/card_border"/>

    <!-- Data grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Soot -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_cell_left">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SOOT" android:textSize="9sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="3dp"/>
            <TextView android:id="@+id/tvSootChange"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Peak EGT -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:padding="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="EGT PICCO" android:textSize="9sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="3dp"/>
            <TextView android:id="@+id/tvPeakEgt"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textStyle="bold" android:textColor="#FF9F0A"/>
        </LinearLayout>

        <!-- Coolant -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:padding="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="COOLANT" android:textSize="9sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="3dp"/>
            <TextView android:id="@+id/tvCoolant"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Warning note (shown only for INTERRUPTED) -->
    <TextView
        android:id="@+id/tvWarningNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textSize="11sp"
        android:textColor="#FF9F0A"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone"
        android:background="@drawable/bg_warn_note"/>

</LinearLayout>
