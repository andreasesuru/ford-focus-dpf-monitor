<?xml version="1.0" encoding="utf-8"?>
<!--
    Maintenance reminder card.
    Left accent border (4dp) changes color based on status:
      green  = OK
      amber  = IN SCADENZA (< 1000 km)
      red    = SCADUTO / URGENTE (< 500 km or overdue)
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Colored left accent border -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/status_ok"/>

        <!-- Card content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Row 1: Title + status badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tagliando olio"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- Status badge (OK / IN SCADENZA / SCADUTO) -->
                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OK"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_ok"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_num_badge"/>

                <!-- Centralina badge — shown only for auto-managed entries -->
                <TextView
                    android:id="@+id/tvAutoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ECU"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#7A8FA6"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_num_badge"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Row 2: Progress bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/bg_progress_ok"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="8dp"/>

            <!-- Row 3: km remaining label -->
            <TextView
                android:id="@+id/tvKmRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scade tra 12.500 km"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Row 4: detail line -->
            <TextView
                android:id="@+id/tvDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fatto a 95.230 km  ·  Prossimo a 110.230 km"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"/>

            <!-- Row 5: action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Delete button (hidden for auto-managed) -->
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Elimina"
                    android:textSize="12sp"
                    android:textColor="#FF3B30"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>

                <!-- Edit button (hidden for auto-managed) -->
                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Modifica"
                    android:textSize="12sp"
                    android:textColor="#7A8FA6"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginStart="0dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>

                <!-- "Fatto" button — hidden for auto-managed -->
                <Button
                    android:id="@+id/btnDone"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Fatto"
                    android:textSize="12sp"
                    android:backgroundTint="#003478"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
