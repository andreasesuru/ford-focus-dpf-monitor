<?xml version="1.0" encoding="utf-8"?>
<!--
    DiagnosticaActivity layout — "📡 Diagnostica" tab.
    Shows live engine sensors + advanced DPF data from the OBD2 dongle.
    Standard OBD2 PIDs (confirmed universally) + Ford-specific pending PIDs.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Tab bar (shared across all screens) ──────────────────────────── -->
    <include layout="@layout/layout_tab_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ── Not-connected banner — shown when BLE is disconnected ─────────── -->
    <TextView
        android:id="@+id/tvNotConnectedBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ Dongle OBD2 non connesso — collegati dal tab Monitor per vedere i dati live"
        android:textColor="#FF9F0A"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:paddingHorizontal="16dp"
        android:background="#1A2D0A00"
        android:visibility="visible"/>

    <!-- ── Scrollable content ────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/contentBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Plain wrapper — shimmer removed (incompatible with MPAndroidChart LineChart) -->
        <LinearLayout
            android:id="@+id/shimmerDiagnostica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION: DPF AVANZATO                                     -->
            <!-- ══════════════════════════════════════════════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥  DPF AVANZATO"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtro antiparticolato — valori live dalla ECU"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <!-- DPF card: Soot / Load / Delta P / EGT pre / EGT post / ΔT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Row 1: Soot % | Load % -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellSoot"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellLoad"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_border"/>

                    <!-- Row 2: Delta P | EGT pre-DPF -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellDeltaP"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellEgtPre"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_border"/>

                    <!-- Row 3: EGT post-DPF | ΔT (pre−post) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellEgtPost"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellDeltaEgt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION: MOTORE LIVE                                      -->
            <!-- ══════════════════════════════════════════════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️  MOTORE LIVE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensori motore — lettura OBD2 in tempo reale"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <!-- Engine sensors card: RPM / Speed / Load / Boost / Coolant / Oil -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Row 1: RPM | Speed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellRpm"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_border"/>

                    <!-- Row 2: Engine Load | Boost (MAP) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellEngineLoad"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellBoost"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_border"/>

                    <!-- Row 3: Coolant (full width — oil temp PID 01 5C not available on this ECU) -->
                    <include layout="@layout/item_diag_cell"
                        android:id="@+id/cellCoolant"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION: DISTANZE                                         -->
            <!-- ══════════════════════════════════════════════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍  DISTANZE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contatori chilometri letti dalla ECU"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Row 1: Km since regen | Km since oil change -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellKmRegen"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/card_border"/>

                        <include layout="@layout/item_diag_cell"
                            android:id="@+id/cellKmOil"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/card_border"/>

                    <!-- Row 2: Odometer (full width — baro PID 01 33 not available on this ECU) -->
                    <include layout="@layout/item_diag_cell"
                        android:id="@+id/cellOdometer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ── Footer (shared) ──────────────────────────────────────────────── -->
    <include layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
