<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash theme — black window from the very first frame, no white flash -->
    <style name="Theme.FordFocusDPFScan.Splash" parent="Theme.FordFocusDPFScan">
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Circular clip for ShapeableImageView (splash icon) -->
    <style name="ShapeCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.FordFocusDPFScan" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Brand colours -->
        <item name="colorPrimary">@color/dpf_blue_light</item>
        <item name="colorPrimaryVariant">@color/dpf_blue_mid</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/dpf_orange</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Surface / background — forces Material cards, dialogs, sheets
             to use the dark-blue palette instead of default grey surfaces.
             NOTE: colorBackground (no namespace) is NOT a valid MDC attribute —
             only android:colorBackground is. colorOnBackground IS valid in MDC. -->
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status bar / nav bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Android 15 (API 35) forces edge-to-edge, which makes the app draw
             behind the status bar. We opt out since the app manages its own
             header layout and does not need edge-to-edge behaviour. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
