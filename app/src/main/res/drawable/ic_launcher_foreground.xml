<?xml version="1.0" encoding="utf-8"?>
<!--
    Ford Focus Mk3 — front view icon, faithful to the reference image.
    Style: white car silhouette on Ford Blue (#003478) background,
           blue accented headlights and fog lights, Ford oval badges.

    Canvas: 108×108 dp  |  Safe zone: x=21..87, y=21..87
    All primary shapes sit inside the safe zone.
    Side mirrors intentionally touch the edge — they are at the circle perimeter
    in the reference image and will be cleanly cropped by the launcher mask.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── INNER RING — subtle circle border matching reference image ───────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1A5599"
        android:strokeWidth="1.5"
        android:pathData="M 5,54 A 49,49 0 1,0 103,54 A 49,49 0 1,0 5,54 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         CAR BODY — white outer silhouette
         Wider at bumper, narrower at roof — Ford Focus front profile.
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="
          M 37,25 L 71,25
          L 83,37 L 87,52
          L 85,65 L 81,83
          L 27,83 L 23,65
          L 21,52 L 25,37 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         WINDSHIELD — Ford Blue trapezoid (wider at bottom)
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#003478"
        android:pathData="M 40,27 L 68,27 L 74,46 L 34,46 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         LEFT HEADLIGHT — Ford Blue angular shape
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#003478"
        android:pathData="M 21,53 L 34,46 L 34,64 L 23,66 L 21,60 Z"/>

    <!-- Left DRL accent — lighter blue glow strip -->
    <path
        android:strokeColor="#4499DD"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 23,58 L 33,53"/>

    <!-- Left DRL secondary strip -->
    <path
        android:strokeColor="#66AAEE"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 23,61 L 33,56"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         RIGHT HEADLIGHT — mirror of left
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#003478"
        android:pathData="M 87,53 L 74,46 L 74,64 L 85,66 L 87,60 Z"/>

    <!-- Right DRL accent -->
    <path
        android:strokeColor="#4499DD"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 85,58 L 75,53"/>

    <!-- Right DRL secondary strip -->
    <path
        android:strokeColor="#66AAEE"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 85,61 L 75,56"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         GRILLE — Ford Blue trapezoidal area (wider at bottom)
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#003478"
        android:pathData="M 34,64 L 74,64 L 78,82 L 30,82 Z"/>

    <!-- Grille inner border line -->
    <path
        android:strokeColor="#1A5599"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M 36,66 L 72,66 L 76,81 L 32,81 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         HOOD FORD OVAL BADGE — centre (54, 55)
         White outer ring, Ford Blue inner fill
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 46,55 A 8,4.5 0 1,0 62,55 A 8,4.5 0 1,0 46,55 Z"/>
    <path
        android:fillColor="#003478"
        android:pathData="M 48.5,55 A 5.5,3 0 1,0 59.5,55 A 5.5,3 0 1,0 48.5,55 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         GRILLE FORD OVAL BADGE — centre (54, 73)
         Larger oval, same style
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 45,73 A 9,5 0 1,0 63,73 A 9,5 0 1,0 45,73 Z"/>
    <path
        android:fillColor="#003478"
        android:pathData="M 47.5,73 A 6.5,3.3 0 1,0 60.5,73 A 6.5,3.3 0 1,0 47.5,73 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         HOOD CREASE LINES — V-shape from windshield base down to grille
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:strokeColor="#CCCCCC"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,46 L 47,63"/>
    <path
        android:strokeColor="#CCCCCC"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,46 L 61,63"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         BUMPER SECTION
    ══════════════════════════════════════════════════════════════════════ -->
    <!-- Bumper separation line -->
    <path
        android:strokeColor="#AAAAAA"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M 25,68 L 83,68"/>

    <!-- Left fog light recess — blue accent -->
    <path
        android:fillColor="#003478"
        android:pathData="M 27,70 L 34,70 L 34,81 L 27,81 Z"/>
    <path
        android:strokeColor="#4499DD"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M 28,72 L 33,72 L 33,79 L 28,79 Z"/>

    <!-- Right fog light recess — blue accent -->
    <path
        android:fillColor="#003478"
        android:pathData="M 74,70 L 81,70 L 81,81 L 74,81 Z"/>
    <path
        android:strokeColor="#4499DD"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M 75,72 L 80,72 L 80,79 L 75,79 Z"/>

    <!-- License plate recess -->
    <path
        android:fillColor="#002560"
        android:pathData="M 43,70 L 65,70 L 65,81 L 43,81 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         SIDE MIRRORS — white, touch the circle edge (cleanly cropped by mask)
    ══════════════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 17,46 L 21,46 L 21,55 L 17,55 Z"/>
    <path
        android:fillColor="#003478"
        android:pathData="M 18,47 L 20,47 L 20,50 L 18,50 Z"/>

    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 87,46 L 91,46 L 91,55 L 87,55 Z"/>
    <path
        android:fillColor="#003478"
        android:pathData="M 88,47 L 90,47 L 90,50 L 88,50 Z"/>

</vector>
