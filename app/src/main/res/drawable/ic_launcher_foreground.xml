<?xml version="1.0" encoding="utf-8"?>
<!--
    Ford Focus Mk3 — front view flat icon (simplified geometric version).
    Uses only straight lines, simple arcs and basic shapes — no complex bezier
    curves — to guarantee correct rendering at all launcher sizes.

    Color scheme: white car body / dark-blue (#1A237E) details on the adaptive
    icon background (also #1A237E), creating the same two-tone look as the
    reference image.

    Adaptive-icon safe zone: x = 18..90, y = 18..90  (108×108 viewport).
    All key shapes sit inside x = 22..86, y = 24..86.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════════════════════════════
         CAR BODY — white, trapezoidal silhouette
         Viewed from the front: narrower at roof, widest at bonnet/bumper.
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 38,28 L 70,28
          L 84,42 L 86,54
          L 84,68 L 80,82
          L 28,82 L 24,68
          L 22,54 L 24,42 Z"/>

    <!-- ═══════════════════════════════════════════════════════════════
         WINDSHIELD — dark blue trapezoid (wider at bottom)
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 41,31 L 67,31 L 71,47 L 37,47 Z"/>

    <!-- ═══════════════════════════════════════════════════════════════
         LEFT HEADLIGHT — angular quad, Ford Focus style
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 24,52 L 37,47 L 37,64 L 25,66 L 22,60 L 22,54 Z"/>

    <!-- Left DRL strip (white line inside headlight) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 27,57 L 36,54"/>

    <!-- ═══════════════════════════════════════════════════════════════
         RIGHT HEADLIGHT — mirror of left
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 84,52 L 71,47 L 71,64 L 83,66 L 86,60 L 86,54 Z"/>

    <!-- Right DRL strip -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 81,57 L 72,54"/>

    <!-- ═══════════════════════════════════════════════════════════════
         FRONT GRILLE — dark blue trapezoid (wider at bottom)
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 37,64 L 71,64 L 75,78 L 33,78 Z"/>

    <!-- ═══════════════════════════════════════════════════════════════
         FORD OVAL BADGE — white ring on grille
         Full ellipse drawn as two half-arcs.
    ═══════════════════════════════════════════════════════════════ -->
    <!-- Outer white ellipse: centre (54,71), rx=9, ry=5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 45,71 A 9,5 0 1,0 63,71 A 9,5 0 1,0 45,71 Z"/>
    <!-- Inner dark ellipse: centre (54,71), rx=6.5, ry=3.2 -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 47.5,71 A 6.5,3.2 0 1,0 60.5,71 A 6.5,3.2 0 1,0 47.5,71 Z"/>

    <!-- ═══════════════════════════════════════════════════════════════
         HOOD CREASE LINES — subtle V from windshield base to grille
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:strokeColor="#CCCCCC"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,47 L 49,62"/>
    <path
        android:strokeColor="#CCCCCC"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,47 L 59,62"/>

    <!-- ═══════════════════════════════════════════════════════════════
         BUMPER DETAILS
    ═══════════════════════════════════════════════════════════════ -->
    <!-- Left fog-light recess -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 26,74 L 34,74 L 34,81 L 26,81 Z"/>
    <!-- Right fog-light recess -->
    <path
        android:fillColor="#1A237E"
        android:pathData="M 74,74 L 82,74 L 82,81 L 74,81 Z"/>
    <!-- Licence-plate recess (slightly lighter) -->
    <path
        android:fillColor="#283593"
        android:pathData="M 44,74 L 64,74 L 64,81 L 44,81 Z"/>
    <!-- Bumper separation line -->
    <path
        android:strokeColor="#AAAAAA"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:pathData="M 26,72 L 82,72"/>

    <!-- ═══════════════════════════════════════════════════════════════
         SIDE MIRRORS — small white rectangles just off the body edge
    ═══════════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 19,49 L 23,49 L 23,56 L 19,56 Z"/>
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 85,49 L 89,49 L 89,56 L 85,56 Z"/>

</vector>
